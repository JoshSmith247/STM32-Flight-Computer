LAPTOP_IP=192.168.4.2
VIDEO_PORT=5600
GCS_PORT=14550
PI_IP=192.168.4.1
WEED_TARGET_PORT=5700

# Camera model — used by station.py and weed_map.py
# CAM_HFOV: horizontal field of view in degrees (Pi Camera v2 wide = 62, standard = 48)
# WORLD_REMATCH_DIST: metres radius a lost weed must reappear within to be re-identified
CAM_HFOV=62.0
WORLD_REMATCH_DIST=0.4

# ExG weed detection tuning
# EXG_THRESH: 2G-R-B cutoff; lower = more sensitive (more false positives on concrete)
# EXG_MIN_AREA: minimum green blob size in px²; raise to ignore tiny specks
# EXG_SAT_MIN: HSV saturation floor (0-255); raise to reject grey rocks/concrete more aggressively
# EXG_MAX_FRAC: max blob size as a fraction of total frame area (0–1); rejects large grass patches
EXG_THRESH=20.0
EXG_MIN_AREA=250
EXG_SAT_MIN=40
EXG_MAX_FRAC=0.04

# weed_map.py — standalone top-down mosaic builder
# MAP_SCALE: canvas pixels per metre; 20 = 200×200 m at 4000×4000 px; raise for more detail
MAP_SCALE=20.0
